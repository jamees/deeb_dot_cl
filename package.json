{
  "name": "deeb-dot-cl",
  "version": "1.0.0",
  "description": "deeb STUDIO & Advisory - Sitio web corporativo",
  "main": "index.html",
  "scripts": {
    "dev": "live-server --port=3000 --open=/ --watch=.",
    "start": "npm run dev",
    "build": "npm run minify:css && npm run minify:js",
    "minify:css": "cleancss -o dist/css/style.min.css css/modern-style.css",
    "minify:js": "terser js/main.js -o dist/js/main.min.js",
    "serve": "http-server -p 8080 -o"
  },
  "keywords": [
    "deeb",
    "studio",
    "advisory",
    "web",
    "development"
  ],
  "author": "deeb STUDIO",
  "license": "ISC",
  "devDependencies": {
    "live-server": "^1.2.2",
    "clean-css-cli": "^5.6.3",
    "terser": "^5.27.0",
    "http-server": "^14.1.1"
  }
}
